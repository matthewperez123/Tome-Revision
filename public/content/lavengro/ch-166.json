"romany-chal\">\n\t\t\t\t\t<dfn>Romany Chal</dfn>\n\t\t\t\t</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<p>Gypsy.</p>\n\t\t\t\t</dd>\n\t\t\t\t<dt id=\"romany-chi\">\n\t\t\t\t\t<dfn>Romany Chi</dfn>\n\t\t\t\t</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<p>Gypsy (girl).</p>\n\t\t\t\t</dd>\n\t\t\t\t<dt id=\"romany-rye\">\n\t\t\t\t\t<dfn>Romany Rye</dfn>\n\t\t\t\t</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<p>Gypsy gentleman.</p>\n\t\t\t\t</dd>\n\t\t\t\t<dt id=\"romany\">\n\t\t\t\t\t<dfn>Romany</dfn>\n\t\t\t\t</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<p>(Anglicised form of <em>RomanÃģ</em>, <em>RomanÃ­</em>), Gypsy.</p>\n\t\t\t\t</dd>\n\t\t\t\t<dt id=\"rome-and-dree\">\n\t\t\t\t\t<dfn>Rome and dree</dfn>\n\t\t\t\t</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<p>(Rom andrÃĐ? Gypsy at heart).</p>\n\t\t\t\t</dd>\n\t\t\t\t<dt id=\"romi\">\n\t\t\t\t\t<dfn>RomÃ­</dfn>\n\t\t\t\t</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<p>Wife.</p>\n\t\t\t\t</dd>\n\t\t\t\t<dt id=\"rommanis\">\n\t\t\t\t\t<dfn>Rommanis</dfn>\n\t\t\t\t</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<p>In Gypsy, also wife (George Borrow).</p>\n\t\t\t\t</dd>\n\t\t\t\t<dt id=\"rommany\">\n\t\t\t\t\t<dfn>Rommany</dfn>\n\t\t\t\t</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<p><abbr>I.q.</abbr> <em>Romany</em>.</p>\n\t\t\t\t</dd>\n\t\t\t\t<dt id=\"rove\">\n\t\t\t\t\t<dfn>RovÃĐ</dfn>\n\t\t\t\t</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<p>(Third person singular of <em>rovava</em>), he weeps.</p>\n\t\t\t\t</dd>\n\t\t\t\t<dt>\n\t\t\t\t\t<dfn>Rup</dfn>\n\t\t\t\t</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<p>Silver.</p>\n\t\t\t\t</dd>\n\t\t\t\t<dt id=\"rye\">\n\t\t\t\t\t<dfn>Rye</dfn>\n\t\t\t\t</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<p>(<em>RÃĄÃŊ</em>), gentleman.</p>\n\t\t\t\t</dd>\n\t\t\t\t<dt id=\"sanpriel\">\n\t\t\t\t\t<dfn>Sanpriel</dfn>\n\t\t\t\t</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<p>Sanspareil.</p>\n\t\t\t\t</dd>\n\t\t\t\t<dt id=\"sap\">\n\t\t\t\t\t<dfn>Sap</dfn>\n\t\t\t\t</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<p>Snake.</p>\n\t\t\t\t</dd>\n\t\t\t\t<dt id=\"sapengro\">\n\t\t\t\t\t<dfn>Sapengro</dfn>\n\t\t\t\t</dt>\n\t\t\t\t<dd>\n\t\t\t\t\t<p>Snake-catcher.</p>\n\t\t\t\t</d