  "html": "<h3>\n\t\t\t\t\t<span>Scene</span>\n\t\t\t\t\t<span>II</span>\n\t\t\t\t</h3>\n\t\t\t\t<table>\n\t\t\t\t\t<tbody>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td/>\n\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t<em><b>Elmire</b>, <b>Mariane</b>, <b>Cléante</b>, <b>Dorine</b>.</em>\n\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td>Dorine</td>\n\t\t\t\t\t\t\t<td>\n\t\t\t\t\t\t\t\t<p>\n\t\t\t\t\t\t\t\t\t<span><em>To <b>Cléante</b>.</em> Sir, we beg you</span>\n\t\t\t\t\t\t\t\t\t<br/>\n\t\t\t\t\t\t\t\t\t<span>To help us all you can in her behalf;</span>\n\t\t\t\t\t\t\t\t\t<br/>\n\t\t\t\t\t\t\t\t\t<span>She’s suffering almost more than heart can bear;</span>\n\t\t\t\t\t\t\t\t\t<br/>\n\t\t\t\t\t\t\t\t\t<span>This match her father means to make tonight</span>\n\t\t\t\t\t\t\t\t\t<br/>\n\t\t\t\t\t\t\t\t\t<span>Drives her each moment to despair. He’s coming.</span>\n\t\t\t\t\t\t\t\t\t<br/>\n\t\t\t\t\t\t\t\t\t<span>Let us unite our efforts now, we beg you,</span>\n\t\t\t\t\t\t\t\t\t<br/>\n\t\t\t\t\t\t\t\t\t<span>And try by strength or skill to change his purpose.</span>\n\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t</tbody>\n\t\t\t\t</table>\n\t\t\t</section>\n\t\t\t<section id=\"scene-4-3\">"
