generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Language {
  LATIN
  GREEK
  ARAMAIC
  ARABIC
  OLD_ENGLISH
  SPANISH
  ITALIAN
  FRENCH
  GERMAN
  RUSSIAN
  SANSKRIT
  HINDI
  TIBETAN
  SCOTS_GAELIC
  HEBREW
}

enum Difficulty {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum Mastery {
  NEW
  LEARNING
  MASTERED
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String?
  passwordHash       String?
  image              String?
  preferredLanguages Language[] @default([LATIN])
  dailyGoalChapters  Int      @default(3)
  currentLevel       Int      @default(1)
  totalXp            Int      @default(0)
  currentStreak      Int      @default(0)
  longestStreak      Int      @default(0)
  hearts             Int      @default(5)
  coins              Int      @default(0)
  lastReadAt         DateTime?
  lastHeartRefill    DateTime?
  streakFreezes      Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  vocabulary      UserVocabulary[]
  readingProgress ReadingProgress[]
  achievements    Achievement[]
  quizResults     QuizResult[]
  leaderboard     LeaderboardEntry[]
  highlights      Highlight[]
  annotations     Annotation[]
  accounts        Account[]
  sessions        Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Book {
  id           String     @id @default(cuid())
  title        String
  author       String
  language     Language
  difficulty   Difficulty
  genre        String
  wordCount    Int        @default(0)
  chapterCount Int        @default(0)
  synopsis     String     @db.Text
  coverStyle   Json
  pathOrder    Int
  sourceId     String?    // Gutenberg ID or other source reference
  isLocked     Boolean    @default(false)
  isPremium    Boolean    @default(false)
  createdAt    DateTime   @default(now())

  chapters        Chapter[]
  vocabulary      UserVocabulary[]
  readingProgress ReadingProgress[]

  @@index([language, difficulty])
}

model Chapter {
  id             String @id @default(cuid())
  bookId         String
  chapterNumber  Int
  title          String
  paragraphCount Int    @default(0)

  book       Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  paragraphs Paragraph[]
  quizResults QuizResult[]

  @@index([bookId, chapterNumber])
}

model Paragraph {
  id              String @id @default(cuid())
  chapterId       String
  paragraphNumber Int
  originalText    String @db.Text
  englishText     String @db.Text

  chapter          Chapter           @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  readingPositions ReadingProgress[] @relation("CurrentParagraph")
  highlights       Highlight[]
  annotations      Annotation[]

  @@index([chapterId, paragraphNumber])
}

model UserVocabulary {
  id            String   @id @default(cuid())
  userId        String
  word          String
  translation   String
  partOfSpeech  String?
  context       String   @db.Text
  bookId        String
  language      Language
  srsInterval   Int      @default(1)
  nextReviewAt  DateTime @default(now())
  timesReviewed Int      @default(0)
  timesCorrect  Int      @default(0)
  mastery       Mastery  @default(NEW)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id])

  @@index([userId, nextReviewAt])
  @@index([userId, language])
  @@index([userId, bookId])
}

model ReadingProgress {
  id                 String    @id @default(cuid())
  userId             String
  bookId             String
  currentChapterId   String?
  currentParagraphId String?
  percentComplete    Float     @default(0)
  totalTimeMinutes   Int       @default(0)
  wordsRead          Int       @default(0)
  chaptersCompleted  Int       @default(0)
  lastReadAt         DateTime?
  startedAt          DateTime  @default(now())
  completedAt        DateTime?

  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  book             Book       @relation(fields: [bookId], references: [id])
  currentParagraph Paragraph? @relation("CurrentParagraph", fields: [currentParagraphId], references: [id])

  @@unique([userId, bookId])
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String
  iconName    String
  xpAwarded   Int
  earnedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model QuizResult {
  id             String   @id @default(cuid())
  userId         String
  chapterId      String
  score          Int
  totalQuestions  Int
  heartsLost     Int      @default(0)
  xpEarned       Int
  completedAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id])

  @@index([userId])
}

model LeaderboardEntry {
  id            String   @id @default(cuid())
  userId        String
  weekStartDate DateTime
  weeklyXp      Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStartDate])
  @@index([weekStartDate, weeklyXp(sort: Desc)])
}

enum HighlightColor {
  OCEAN
  SAFFRON
  IRIS
  CLOVER
}

model Highlight {
  id           String         @id @default(cuid())
  userId       String
  paragraphId  String
  startOffset  Int
  endOffset    Int
  color        HighlightColor @default(OCEAN)
  createdAt    DateTime       @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  paragraph Paragraph @relation(fields: [paragraphId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([paragraphId])
}

model Annotation {
  id          String   @id @default(cuid())
  userId      String
  paragraphId String
  noteText    String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  paragraph Paragraph @relation(fields: [paragraphId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([paragraphId])
}

model WordParsing {
  id           String   @id @default(cuid())
  word         String
  language     Language
  lemma        String
  partOfSpeech String
  conjugation  String?
  declension   String?
  case_        String?  @map("case")
  number_      String?  @map("number")
  gender       String?
  mood         String?
  tense        String?
  voice        String?
  person       String?
  definition   String   @db.Text
  createdAt    DateTime @default(now())

  @@unique([word, language])
  @@index([language])
}
