  "grammar": [
    {
      "id": "g-nom-acc",
      "title": "Nominative and Accusative Cases",
      "explanation": "Latin nouns change their endings to show their role in a sentence. The <strong>nominative case</strong> marks the subject \u2014 the person or thing performing the action. The <strong>accusative case</strong> marks the direct object \u2014 the person or thing receiving the action. In \"Belgae partem incolunt\" (The Belgae inhabit a part), <em>Belgae</em> is nominative (subject) and <em>partem</em> is accusative (object).",
      "examples": [
        { "latin": "Gallia est divisa.", "english": "Gaul (nominative - subject) is divided." },
        { "latin": "Belgae partem incolunt.", "english": "The Belgae (nom.) inhabit a part (acc.)." }
      ],
      "tip": "Think of nominative as 'the doer' and accusative as 'the receiver.' In English we show this with word order; in Latin, the endings do the work."
    },
    {
      "id": "g-esse",
      "title": "The Verb 'esse' (to be)",
      "explanation": "The verb <strong>esse</strong> (to be) is the most important and most irregular verb in Latin. In the present tense: <em>sum</em> (I am), <em>es</em> (you are), <em>est</em> (he/she/it is), <em>sumus</em> (we are), <em>estis</em> (you all are), <em>sunt</em> (they are). It is used with predicate nouns and adjectives, just like English 'is/are'.",
      "examples": [
        { "latin": "Gallia est divisa.", "english": "Gaul is divided." },
        { "latin": "Horum omnium fortissimi sunt Belgae.", "english": "Of all these, the Belgae are the bravest." }
      ],
      "tip": "Unlike most Latin verbs, 'esse' does not take a direct object. It links the subject to a description or identity."
    }
  ],

