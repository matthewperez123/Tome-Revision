  "grammar": [
    {
      "id": "g-subjunctive",
      "title": "The Hortatory (Jussive) Subjunctive",
      "explanation": "The <strong>hortatory subjunctive</strong> uses the first person plural ('we') of the present subjunctive to express an exhortation or encouragement \u2014 'let us...' In <em>vivamus</em> and <em>amemus</em>, Catullus is urging both himself and Lesbia: 'Let us live! Let us love!' This is one of the most common independent uses of the subjunctive mood in Latin.",
      "examples": [
        { "latin": "Vivamus atque amemus.", "english": "Let us live and let us love." },
        { "latin": "Aestimemus assis.", "english": "Let us value (it) at a single penny." }
      ],
      "tip": "When you see a 1st person plural verb that doesn't seem to be a statement of fact, it's likely hortatory: 'let us do X.'"
    },
    {
      "id": "g-numbers",
      "title": "Numbers in Latin",
      "explanation": "Catullus plays with numbers throughout Carmen 5: <em>mille</em> (1,000), <em>centum</em> (100), <em>unius</em> (one). Key numbers: <strong>unus</strong> (1), <strong>duo</strong> (2), <strong>tres</strong> (3), <strong>centum</strong> (100), <strong>mille</strong> (1,000). 'Mille' is indeclinable in the singular but becomes the neuter noun 'milia' in the plural (thousands).",
      "examples": [
        { "latin": "Da mi basia mille, deinde centum.", "english": "Give me a thousand kisses, then a hundred." },
        { "latin": "Dein mille altera, dein secunda centum.", "english": "Then another thousand, then a second hundred." }
      ],
      "tip": "Catullus piles up huge numbers to express overwhelming passion \u2014 and then says 'let us mix them up' so no one can count them and cast the evil eye!"
    }
  ],

