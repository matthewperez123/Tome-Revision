{
  "id": "lesson-greek-002",
  "languageId": "greek",
  "title": "Socrates Before the Jury",
  "author": "Plato",
  "workTitle": "Apology",
  "workSection": "17a",

  "vocabulary": [
    {
      "id": "v-hymeis",
      "word": "\u1f51\u03bc\u03b5\u1fd6\u03c2",
      "lemma": "\u1f51\u03bc\u03b5\u1fd6\u03c2",
      "partOfSpeech": "pronoun",
      "definition": "you (plural), you all",
      "pronunciation": { "classical": "/hy.me\u0302\u02d0s/" },
      "exampleSentence": "\u1f59\u03bc\u03b5\u1fd6\u03c2, \u1f66 \u1f04\u03bd\u03b4\u03c1\u03b5\u03c2 \u1f08\u03b8\u03b7\u03bd\u03b1\u1fd6\u03bf\u03b9.",
      "exampleTranslation": "You, men of Athens.",
      "notes": "Transliteration: hyme\u012bs. The plural 'you,' addressing the jury of 501 citizens."
    },
    {
      "id": "v-pascho",
      "word": "\u03c0\u03b5\u03c0\u03cc\u03bd\u03b8\u03b1\u03c4\u03b5",
      "lemma": "\u03c0\u03ac\u03c3\u03c7\u03c9",
      "partOfSpeech": "verb",
      "definition": "to experience, suffer, be affected",
      "pronunciation": { "classical": "/p\u00e1s.k\u02b0\u0254\u02d0/" },
      "exampleSentence": "\u03bf\u1f50\u03ba \u03bf\u1f36\u03b4\u03b1 \u1f45 \u03c4\u03b9 \u1f51\u03bc\u03b5\u1fd6\u03c2 \u03c0\u03b5\u03c0\u03cc\u03bd\u03b8\u03b1\u03c4\u03b5.",
      "exampleTranslation": "I do not know how you have been affected.",
      "notes": "Transliteration: pasch\u014d. Root of English 'passion' (originally meaning 'suffering')."
    },
    {
      "id": "v-aletheia",
      "word": "\u1f00\u03bb\u03ae\u03b8\u03b5\u03b9\u03b1\u03bd",
      "lemma": "\u1f00\u03bb\u03ae\u03b8\u03b5\u03b9\u03b1",
      "partOfSpeech": "noun",
      "gender": "feminine",
      "definition": "truth",
      "pronunciation": { "classical": "/a.l\u025b\u0301\u02d0.t\u02b0ei\u032f.a/" },
      "exampleSentence": "\u1f10\u03b3\u1f7c \u03b4\u1f72 \u03c4\u1f74\u03bd \u1f00\u03bb\u03ae\u03b8\u03b5\u03b9\u03b1\u03bd \u1f10\u03c1\u1ff6.",
      "exampleTranslation": "But I will speak the truth.",
      "notes": "Transliteration: al\u0113theia. Literally 'un-hiddenness.' A fundamental concept in Greek philosophy."
    },
    {
      "id": "v-lego",
      "word": "\u03bb\u03ad\u03b3\u03c9",
      "lemma": "\u03bb\u03ad\u03b3\u03c9",
      "partOfSpeech": "verb",
      "definition": "to say, speak, tell",
      "pronunciation": { "classical": "/l\u00e9.g\u0254\u02d0/" },
      "exampleSentence": "\u03bf\u1f50\u03b4\u1f72\u03bd \u1f00\u03bb\u03b7\u03b8\u1f72\u03c2 \u1f14\u03bb\u03b5\u03b3\u03bf\u03bd.",
      "exampleTranslation": "They said nothing true.",
      "notes": "Transliteration: leg\u014d. One of the most common Greek verbs. Related to 'logos' (word, reason)."
    },
    {
      "id": "v-dikastes",
      "word": "\u03b4\u03b9\u03ba\u03b1\u03c3\u03c4\u03b1\u03af",
      "lemma": "\u03b4\u03b9\u03ba\u03b1\u03c3\u03c4\u03ae\u03c2",
      "partOfSpeech": "noun",
      "gender": "masculine",
      "definition": "juror, judge",
      "pronunciation": { "classical": "/di.kas.t\u025b\u0301\u02d0s/" },
      "exampleSentence": "\u1f66 \u1f04\u03bd\u03b4\u03c1\u03b5\u03c2 \u03b4\u03b9\u03ba\u03b1\u03c3\u03c4\u03b1\u03af.",
      "exampleTranslation": "O men of the jury.",
      "notes": "Transliteration: dikasta\u012b. From dik\u0113 (justice). Athenian juries were large citizen panels."
    },
    {
      "id": "v-kategoros",
      "word": "\u03ba\u03b1\u03c4\u03b7\u03b3\u03cc\u03c1\u03c9\u03bd",
      "lemma": "\u03ba\u03b1\u03c4\u03ae\u03b3\u03bf\u03c1\u03bf\u03c2",
      "partOfSpeech": "noun",
