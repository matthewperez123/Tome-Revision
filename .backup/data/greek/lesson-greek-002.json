      "pronunciation": { "classical": "/ka.t\u025b\u0301\u02d0.go.ros/" },
      "exampleSentence": "\u03bf\u1f31 \u1f10\u03bc\u03bf\u1f76 \u03ba\u03b1\u03c4\u03ae\u03b3\u03bf\u03c1\u03bf\u03b9.",
      "exampleTranslation": "My accusers.",
      "notes": "Transliteration: kat\u0113goros. Root of English 'category' (originally an accusation in the assembly)."
    },
    {
      "id": "v-deinos",
