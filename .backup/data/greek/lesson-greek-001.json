  "grammar": [
    {
      "id": "g-alphabet",
      "title": "The Greek Alphabet: First Steps",
      "explanation": "Ancient Greek uses its own alphabet of 24 letters. Many are familiar from math and science: <strong>\u03b1</strong> (alpha), <strong>\u03b2</strong> (beta), <strong>\u03b3</strong> (gamma), <strong>\u03b4</strong> (delta). Key vowels: \u03b1 (a), \u03b5 (e, short), \u03b7 (\u0113, long e), \u03b9 (i), \u03bf (o, short), \u03c9 (\u014d, long o), \u03c5 (y/u). Greek also uses breathing marks: a rough breathing (\u1f01) = 'h' sound, smooth breathing (\u1f00) = no 'h'. Accents (\u03ac \u1fb6 \u1f05) show pitch, not stress.",
      "examples": [
        { "greek": "\u03bc\u1fc6\u03bd\u03b9\u03bd = m-\u0113-n-i-n", "english": "wrath (mu, eta, nu, iota, nu)" },
        { "greek": "\u03b8\u03b5\u03ac = th-e-a", "english": "goddess (theta, epsilon, alpha)" }
      ],
      "tip": "Don't try to memorize the whole alphabet at once. Learn the letters as you encounter them in real words. Many Greek letters are ancestors of our Latin alphabet: A=\u0391, B=\u0392, etc."
    },
    {
      "id": "g-nom-acc-greek",
      "title": "Nominative and Accusative in Greek",
      "explanation": "Like Latin, Greek uses <strong>cases</strong> to show a word's role in a sentence. The <strong>nominative</strong> marks the subject, and the <strong>accusative</strong> marks the direct object. In <em>\u039c\u1fc6\u03bd\u03b9\u03bd \u1f04\u03b5\u03b9\u03b4\u03b5, \u03b8\u03b5\u03ac</em>, '\u03bc\u1fc6\u03bd\u03b9\u03bd' is accusative (the object of singing) and '\u03b8\u03b5\u03ac' is vocative/nominative (the goddess being addressed). Greek accusative singular often ends in <strong>-\u03bd</strong> (-n).",
      "examples": [
        { "greek": "\u03bc\u1fc6\u03bd\u03b9\u03bd (acc.) \u1f04\u03b5\u03b9\u03b4\u03b5", "english": "Sing of the wrath (accusative = object)" },
        { "greek": "\u03c8\u03c5\u03c7\u03b1\u03c2 (acc. pl.) \u03c0\u03c1\u03bf\u0390\u03b1\u03c8\u03b5\u03bd", "english": "It sent forth souls (accusative plural)" }
      ],
      "tip": "The -\u03bd ending on \u03bc\u1fc6\u03bd\u03b9\u03bd and -\u03b1\u03c2 on \u03c8\u03c5\u03c7\u03ac\u03c2 are accusative markers. Compare Latin: -m (sg.) and -s (pl.)."
    }
  ],

